generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id         String   @id @default(uuid())
  email      String   @unique
  passwordHash String @map("password_hash")
  fullName   String   @map("full_name")
  role       String   @default("candidate")
  avatarUrl  String?  @map("avatar_url")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @map("updated_at")

  resumes    Resume[]
  interviews Interview[]
  reports    Report[]
}

model Resume {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  fileName            String   @map("file_name")
  filePath            String   @map("file_path")
  fileType            String   @map("file_type")
  rawText             String?  @map("raw_text")
  parsedData          Json?    @map("parsed_data")
  chromadbCollectionId String?  @map("chromadb_collection_id")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @map("updated_at")

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews          Interview[]
}

model Interview {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  resumeId       String?  @map("resume_id")
  targetRole     String   @map("target_role")
  interviewType  String   @map("interview_type")
  difficulty     String
  durationMinutes Int     @map("duration_minutes")
  company        String?
  status         String   @default("pending")
  currentScore   Float?   @map("current_score")
  totalQuestions Int?     @map("total_questions")
  agentState     Json?    @map("agent_state")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume         Resume?  @relation(fields: [resumeId], references: [id])
  questions      InterviewQuestion[]
  report         Report?  @relation(fields: [id], references: [interview_id])
}

model InterviewQuestion {
  id             String   @id @default(uuid())
  interviewId    String   @map("interview_id")
  questionNumber Int      @map("question_number")
  questionText   String   @map("question_text")
  questionType   String?  @map("question_type")
  difficultyLevel String? @map("difficulty_level")
  candidateAnswer String? @map("candidate_answer")
  answerMode     String   @map("answer_mode") @default("text")
  voiceTranscript String? @map("voice_transcript")
  aiEvaluation   Json?    @map("ai_evaluation")
  score          Float?
  followUpOf     String?  @map("follow_up_of")
  createdAt      DateTime @default(now()) @map("created_at")

  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  codingSubmissions CodingSubmission[]
}

model Report {
  id                 String   @id @default(uuid())
  interviewId        String   @map("interview_id") @unique
  userId             String   @map("user_id")
  executiveSummary   String?  @map("executive_summary")
  technicalAssessment Json?   @map("technical_assessment")
  behavioralAssessment Json? @map("behavioral_assessment")
  projectKnowledge   Json?   @map("project_knowledge")
  communicationSkills Json?  @map("communication_skills")
  improvementAreas    Json?   @map("improvement_areas")
  learningPath        Json?  @map("learning_path")
  overallScore        Float? @map("overall_score")
  overallGrade        String? @map("overall_grade")
  pdfPath             String? @map("pdf_path")
  createdAt           DateTime @default(now()) @map("created_at")

  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CodingSubmission {
  id               String   @id @default(uuid())
  questionId       String   @map("question_id")
  language         String
  code             String
  testResults      Json?    @map("test_results")
  correctnessScore Float?   @map("correctness_score")
  efficiencyScore  Float?   @map("efficiency_score")
  aiFeedback       Json?    @map("ai_feedback")
  createdAt        DateTime @default(now()) @map("created_at")

  question         InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}