# ============================================
# InterviewGPT Environment Configuration
# ============================================

# Database
DATABASE_URL=postgresql+asyncpg://interviewgpt:interviewgpt_secret@localhost:5432/interviewgpt
POSTGRES_USER=interviewgpt
POSTGRES_PASSWORD=interviewgpt_secret
POSTGRES_DB=interviewgpt

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini AI
GOOGLE_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8100
CHROMA_PERSIST_DIR=./chroma_data

# Faster Whisper
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=InterviewGPT

# File Upload
MAX_UPLOAD_SIZE_MB=10
UPLOAD_DIR=./uploads
